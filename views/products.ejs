<%- include('layout', { title: 'Products', admin: admin, body: '' }) %>

<section>
  <h2>Manage Products</h2>

  <form action="/products/add" method="post">
    <input type="text" name="name" placeholder="Product Name" required />
    <!--input type="text" name="picture_url" placeholder="Image URL" /-->
    <input type="number" name="product_count" placeholder="Count" min="0" />
    <input type="number" step="0.01" name="product_rate" placeholder="Rate" />
    <button type="submit">Add Product</button>
  </form>

  <h3>Existing Products</h3>
  <table border="1">
    <tr>
      <th>ID</th><th>Name</th><th>Rate</th><th>Count</th><th>Action</th>
    </tr>
    <% products.forEach(p => { %>
    <tr>
      <td><%= p.pid %></td>
      <td><%= p.name %></td>
      <td><%= p.product_rate %></td>
      <td><%= p.product_count %></td>
      <td>
        <form action="/products/update-rate" method="post" style="display:inline;">
          <input type="hidden" name="pid" value="<%= p.pid %>" />
          <input type="number" step="0.01" name="product_rate" placeholder="New Rate" required />
          <button type="submit">Update</button>
        </form>
      </td>
    </tr>
    <% }) %>
  </table>
</section>
